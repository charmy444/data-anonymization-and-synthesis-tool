{
  "template_id": "orders",
  "title": "Заказы",
  "columns": [
    {"name": "order_id", "provider": "uuid4"},
    {"name": "user_id", "provider": "context_ref", "ref": "user_id"},
    {
      "name": "amount", 
      "provider": "random_int", 
      "min": 50, 
      "max": 100000
    },
    {"name": "order_date", "provider": "date_this_year"},
    {
      "name": "currency", 
      "provider": "random_element", 
      "elements": ["RUB", "USD"]
    }
  ]
}